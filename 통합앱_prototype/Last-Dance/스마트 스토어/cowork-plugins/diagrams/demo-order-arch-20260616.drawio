        <mxCell id="gw" value="API Gateway" vertex="1" parent="vpc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D97757;strokeColor=#B85C3E;fontColor=#FFFFFF;fontFamily=Helvetica;">
          <mxGeometry x="40" y="150" width="140" height="60" as="geometry" />
